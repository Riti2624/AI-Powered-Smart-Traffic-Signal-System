<configuration>
    <input>
        <net-file value="corridor.net.xml"/>
        <route-files value="corridor.rou.xml"/>
    </input>
    <time>
        <begin value="0"/>
        <end value="3600"/>
        <step-length value="1"/>
    </time>
    <processing>
        <ignore-route-errors value="true"/>
    </processing>
</configuration>
